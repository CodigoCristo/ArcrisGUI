# Maintainer: Cristo

pkgname=arcrisgui
pkgver=0.1
pkgrel=1
pkgdesc="Instalador Gráfico para instalar fácil ArchLinux - Modern GTK4 installer"
arch=('x86_64')
url="https://github.com/CodigoCristo/ArcrisGUI"
license=('GPL3')
depends=('gtk4' 'libadwaita' 'vte4' 'glib2' 'curl' 'wget' 'udisks2')
makedepends=('meson' 'ninja' 'git')
provides=("${pkgname}")
conflicts=("${pkgname}")
source=("${pkgname}::git+$url.git")
sha256sums=('SKIP')

build() {
  cd "${srcdir}/${pkgname}"
  meson setup build --buildtype=release --prefix=/usr
  ninja -C build
}

package() {
  cd "${srcdir}/${pkgname}"
  DESTDIR="${pkgdir}" meson install -C build

  # Create proper directory structure
  install -dm755 "${pkgdir}/usr/lib/${pkgname}"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/config"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/bash"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/bash/xmonad"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/bash/i3"
  install -dm755 "${pkgdir}/usr/share/${pkgname}/data/bash/rofi"
  install -dm755 "${pkgdir}/usr/bin"

  # Move binary from /usr/bin to /usr/lib/arcrisgui/
  if [ -f "${pkgdir}/usr/bin/arcris" ]; then
    mv "${pkgdir}/usr/bin/arcris" "${pkgdir}/usr/lib/${pkgname}/"
  fi

  # Install bash scripts
  install -m755 data/bash/config_conectividad.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/config_kitty.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/config_ly.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/config_teclado.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/driver_audio.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/driver_bluetooth.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/driver_video.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/driver_wifi.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/entorno_grafico.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/program_essential.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m755 data/bash/install.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"
  install -m644 data/bash/variables.sh "${pkgdir}/usr/share/${pkgname}/data/bash/"

  # Install xmonad configuration files
  install -m644 data/bash/xmonad/xinitrc "${pkgdir}/usr/share/${pkgname}/data/bash/xmonad/"
  install -m644 data/bash/xmonad/xmobarrc "${pkgdir}/usr/share/${pkgname}/data/bash/xmonad/"
  install -m644 data/bash/xmonad/xmonad.hs "${pkgdir}/usr/share/${pkgname}/data/bash/xmonad/"

  # Install btrfs configuration files
  install -m644 data/bash/btrfs/btrfs-guide "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/btrfs-maintenance "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/btrfs-maintenance.service "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/btrfs-maintenance.timer "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/config "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/home "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"
  install -m644 data/bash/btrfs/root "${pkgdir}/usr/share/${pkgname}/data/bash/btrfs/"

  # Install i3wm configuration files
  install -m644 data/bash/i3/atajos.txt "${pkgdir}/usr/share/${pkgname}/data/bash/i3/"
  install -m644 data/bash/i3/i3-config.zip "${pkgdir}/usr/share/${pkgname}/data/bash/i3/"
  install -m644 data/bash/rofi/config.rasi "${pkgdir}/usr/share/${pkgname}/data/bash/rofi/"

  # Install other data files
  install -m644 data/PKGBUILD "${pkgdir}/usr/share/${pkgname}/data/"
  install -m644 data/reserved_usernames "${pkgdir}/usr/share/${pkgname}/data/"
  install -m644 data/locale.gen "${pkgdir}/usr/share/${pkgname}/data/"

  # Install config files
  install -m644 data/config/bashrc "${pkgdir}/usr/share/${pkgname}/data/config/"
  install -m644 data/config/bashrc-root "${pkgdir}/usr/share/${pkgname}/data/config/"
  install -m644 data/config/pacman.conf "${pkgdir}/usr/share/${pkgname}/data/config/"
  install -m644 data/config/pacman-chroot.conf "${pkgdir}/usr/share/${pkgname}/data/config/"
  install -m644 data/config/zshrc "${pkgdir}/usr/share/${pkgname}/data/config/"
  install -m644 data/config/sudoers "${pkgdir}/usr/share/${pkgname}/data/config/"

  # Add fallback with full icon path for better compatibility
  sed -i 's|Icon=org.gtk.arcris|Icon=/usr/share/icons/hicolor/scalable/apps/org.gtk.arcris.svg|' "${pkgdir}/usr/share/applications/org.gtk.arcris.desktop"

  echo "$(git rev-parse HEAD)" > "$pkgdir/usr/share/arcrisgui/commit"

  # Create wrapper script that uses user-writable directory
  cat > "${pkgdir}/usr/bin/arcris" << 'EOF'
#!/bin/bash

USER_DATA_DIR="$HOME/.local/share/arcrisgui"
SYSTEM_DATA_DIR="/usr/share/arcrisgui"

# Inicializar directorio si no existe
if [ ! -d "$USER_DATA_DIR/data" ]; then
    mkdir -p "$USER_DATA_DIR"
    cp -r "$SYSTEM_DATA_DIR/data" "$USER_DATA_DIR/"
    echo "Initialized arcrisgui data in $USER_DATA_DIR"
fi

# Copiar PKGBUILD si el commit del sistema es distinto al último copiado
SYSTEM_COMMIT=$(cat "$SYSTEM_DATA_DIR/commit" 2>/dev/null)
CACHED_COMMIT=$(cat "$USER_DATA_DIR/last_commit" 2>/dev/null)

if [ "$SYSTEM_COMMIT" != "$CACHED_COMMIT" ]; then
    echo "==> Nueva versión detectada, actualizando PKGBUILD..."
    cp -r "$SYSTEM_DATA_DIR/data" "$USER_DATA_DIR/"
    cp "$SYSTEM_DATA_DIR/data/PKGBUILD" "/home/arcris/Arcris/PKGBUILD"
    echo "$SYSTEM_COMMIT" > "$USER_DATA_DIR/last_commit"
    echo "==> PKGBUILD actualizado en /home/arcris/Arcris/"
fi

cd "$USER_DATA_DIR"
exec /usr/lib/arcrisgui/arcris "$@"
EOF
  chmod 755 "${pkgdir}/usr/bin/arcris"
}

# Post-install hooks
post_install() {
  echo "==> Arcris GUI Installer has been installed"
  echo "==> You can launch it from the applications menu or run 'arcris' in terminal"
  echo "==> Configuration files will be created in ~/.local/share/arcrisgui/ on first run"

  # Update icon cache
  if command -v gtk-update-icon-cache &> /dev/null; then
    echo "==> Updating icon cache..."
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor
  fi

  # Update desktop database
  if command -v update-desktop-database &> /dev/null; then
    echo "==> Updating desktop database..."
    update-desktop-database -q /usr/share/applications
  fi
}

post_upgrade() {
  post_install
}

post_remove() {
  # Update icon cache
  if command -v gtk-update-icon-cache &> /dev/null; then
    echo "==> Updating icon cache..."
    gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor
  fi

  # Update desktop database
  if command -v update-desktop-database &> /dev/null; then
    echo "==> Updating desktop database..."
    update-desktop-database -q /usr/share/applications
  fi
}
