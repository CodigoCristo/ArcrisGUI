}

# Función para eliminar puntos de restauración
show_delete_restore_points() {
    clear
    show_header "ELIMINAR PUNTOS DE RESTAURACIÓN"

    echo -e "${WHITE}Selecciona qué deseas eliminar:${NC}\n"
    echo -e "${CYAN}1)${NC} 🖥️  Eliminar snapshot de ROOT (/)"
    echo -e "${CYAN}2)${NC} 🏠  Eliminar snapshot de HOME (/home)"
    echo -e "${CYAN}3)${NC} 📦  Eliminar AMBOS (ROOT + HOME) con misma descripción"
    echo -e "${CYAN}4)${NC} 📋  Ver comandos manuales"
    echo -e "${CYAN}0)${NC} ✗  Volver al menú principal"

    echo -e "\n${YELLOW}Ingresa tu opción: ${NC}"
    read -r option

    case $option in
        1)
            clear
            show_header "ELIMINAR SNAPSHOT DE ROOT (/)"
            echo -e "${WHITE}Snapshots disponibles de ROOT:${NC}\n"
            sudo snapper -c root list

            echo -e "\n${WHITE}Ingresa los snapshots a eliminar (o 0 para cancelar):${NC}"
            echo -e "${CYAN}  Un número: ${NC}${WHITE}5${NC}${CYAN}  | Varios: ${NC}${WHITE}1 2 3 4 5${NC}${CYAN}  | Rango: ${NC}${WHITE}5-10${NC}"
            read -r snapshot_input

            if [ "$snapshot_input" = "0" ]; then
                show_delete_restore_points
                return
            fi

            if [ -n "$snapshot_input" ] && [[ "$snapshot_input" =~ ^[0-9]([0-9 -])*$ ]]; then
                echo -e "\n${RED}${BOLD}⚠️  ADVERTENCIA: Esta acción es irreversible${NC}"
                echo -e "${WHITE}¿Estás seguro de que deseas eliminar los snapshots [$snapshot_input] de ROOT? (s/N):${NC}"
                read -r confirm

                if [[ "$confirm" =~ ^[sS]$ ]]; then
                    echo -e "\n${CYAN}Eliminando snapshots [$snapshot_input] de ROOT...${NC}"
                    if sudo snapper -c root delete $snapshot_input; then
                        echo -e "${GREEN}✓ Snapshots [$snapshot_input] de ROOT eliminados correctamente${NC}"
                    else
                        echo -e "${RED}✗ Error al eliminar los snapshots de ROOT${NC}"
                    fi
                else
                    echo -e "${YELLOW}Operación cancelada${NC}"
                fi
            else
                echo -e "${RED}✗ Entrada inválida${NC}"
            fi

            echo -e "\n${YELLOW}Presiona ENTER para continuar...${NC}"
            read
            show_delete_restore_points
            ;;
        2)
            clear
            show_header "ELIMINAR SNAPSHOT DE HOME (/home)"
            echo -e "${WHITE}Snapshots disponibles de HOME:${NC}\n"
            sudo snapper -c home list

            echo -e "\n${WHITE}Ingresa los snapshots a eliminar (o 0 para cancelar):${NC}"
            echo -e "${CYAN}  Un número: ${NC}${WHITE}5${NC}${CYAN}  | Varios: ${NC}${WHITE}1 2 3 4 5${NC}${CYAN}  | Rango: ${NC}${WHITE}5-10${NC}"
            read -r snapshot_input

            if [ "$snapshot_input" = "0" ]; then
                show_delete_restore_points
                return
            fi

            if [ -n "$snapshot_input" ] && [[ "$snapshot_input" =~ ^[0-9]([0-9 -])*$ ]]; then
                echo -e "\n${RED}${BOLD}⚠️  ADVERTENCIA: Esta acción es irreversible${NC}"
                echo -e "${WHITE}¿Estás seguro de que deseas eliminar los snapshots [$snapshot_input] de HOME? (s/N):${NC}"
                read -r confirm

                if [[ "$confirm" =~ ^[sS]$ ]]; then
                    echo -e "\n${CYAN}Eliminando snapshots [$snapshot_input] de HOME...${NC}"
                    if sudo snapper -c home delete $snapshot_input; then
                        echo -e "${GREEN}✓ Snapshots [$snapshot_input] de HOME eliminados correctamente${NC}"
                    else
                        echo -e "${RED}✗ Error al eliminar los snapshots de HOME${NC}"
                    fi
                else
                    echo -e "${YELLOW}Operación cancelada${NC}"
                fi
            else
                echo -e "${RED}✗ Entrada inválida${NC}"
            fi

            echo -e "\n${YELLOW}Presiona ENTER para continuar...${NC}"
            read
            show_delete_restore_points
            ;;
        3)
            clear
            show_header "ELIMINAR AMBOS (ROOT + HOME)"

            echo -e "${WHITE}Esta opción busca snapshots con la misma descripción en ROOT y HOME${NC}"
            echo -e "${YELLOW}Ideal para snapshots creados con la opción 'Crear AMBOS'${NC}\n"

            echo -e "${CYAN}Buscando snapshots con descripciones coincidentes...${NC}\n"

            # Extraer descripción usando el formato real de snapper:
            # Las columnas son: número │ tipo │ fecha │ usuario │ espacio_usado │ limpieza │ descripción
            # Se usa awk con separador │ o | y se toma el ULTIMO campo no vacío
            extract_snap_desc() {
                local line="$1"
                # Primero intentar con │ unicode, luego con | ASCII
                local desc
                desc=$(echo "$line" | awk -F'│' '{
                    gsub(/^[ \t]+|[ \t]+$/, "", $NF)
                    print $NF
                }')
                # Si no funcionó con │, intentar con |
                if [ -z "$desc" ] || echo "$desc" | grep -qE '^[0-9]'; then
                    desc=$(echo "$line" | awk -F'|' '{
                        gsub(/^[ \t]+|[ \t]+$/, "", $NF)
                        print $NF
                    }')
                fi
                echo "$desc"
            }

            # Extraer número de snapshot (primer número de la línea)
            extract_snap_num() {
                echo "$1" | grep -oE '^[[:space:]]*[0-9]+' | tr -d ' '
            }

            TEMP_FILE=$(mktemp)

            # Cargar snapshots de HOME en memoria para comparación eficiente
            declare -A HOME_DESC_MAP  # descripción → número de snapshot HOME
            while IFS= read -r home_line; do
                H_NUM=$(extract_snap_num "$home_line")
                H_DESC=$(extract_snap_desc "$home_line")
                # Solo incluir snapshots válidos: número > 0 y descripción no vacía
                if [ -n "$H_NUM" ] && [ "$H_NUM" -gt 0 ] && [ -n "$H_DESC" ]; then
                    # Si hay duplicados de descripción, guardar el más reciente (mayor número)
                    if [ -z "${HOME_DESC_MAP[$H_DESC]}" ] || [ "$H_NUM" -gt "${HOME_DESC_MAP[$H_DESC]}" ]; then
                        HOME_DESC_MAP["$H_DESC"]="$H_NUM"
                    fi
                fi
            done < <(sudo snapper -c home list | grep -E "^[[:space:]]*[0-9]+")

            # Recorrer snapshots de ROOT y buscar coincidencias en HOME
            while IFS= read -r line; do
                R_NUM=$(extract_snap_num "$line")
                R_DESC=$(extract_snap_desc "$line")

                # Saltar snapshot 0 (estado actual) y descripciones vacías o del sistema
                if [ -z "$R_NUM" ] || [ "$R_NUM" -eq 0 ] || [ -z "$R_DESC" ]; then
                    continue
                fi

                # Buscar si HOME tiene un snapshot con la misma descripción
                if [ -n "${HOME_DESC_MAP[$R_DESC]}" ]; then
                    H_NUM="${HOME_DESC_MAP[$R_DESC]}"
                    echo "$R_NUM|$H_NUM|$R_DESC" >> "$TEMP_FILE"
                fi
            done < <(sudo snapper -c root list | grep -E "^[[:space:]]*[0-9]+")

            if [ -s "$TEMP_FILE" ]; then
                echo -e "${WHITE}Snapshots coincidentes encontrados:${NC}\n"
                echo -e "${CYAN}No. | ROOT | HOME | Descripción${NC}"
                echo -e "${CYAN}----|----- |----- |------------${NC}"

                INDEX=1
                while IFS='|' read -r root_num home_num desc; do
                    printf "${YELLOW}%2d${NC}  | ${GREEN}%4s${NC}  | ${GREEN}%4s${NC}  | ${CYAN}%s${NC}\n" "$INDEX" "$root_num" "$home_num" "$desc"
                    INDEX=$((INDEX + 1))
                done < "$TEMP_FILE"

                echo -e "\n${WHITE}Selecciona las filas a eliminar (0 para cancelar):${NC}"
                echo -e "${CYAN}  Un número: ${NC}${WHITE}1${NC}${CYAN}  | Varios: ${NC}${WHITE}1 2 3${NC}${CYAN}  | Rango: ${NC}${WHITE}1-3${NC}"
                read -r choices_input

                if [ "$choices_input" = "0" ]; then
                    echo -e "${YELLOW}Operación cancelada${NC}"
                elif [ -n "$choices_input" ] && [[ "$choices_input" =~ ^[0-9]([0-9 -])*$ ]]; then
                    # Expandir rangos y espacios a lista de números
                    ROWS=()
                    for token in $choices_input; do
                        if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
                            for ((i=${BASH_REMATCH[1]}; i<=${BASH_REMATCH[2]}; i++)); do
                                ROWS+=("$i")
                            done
                        else
                            ROWS+=("$token")
                        fi
                    done

                    # Mostrar resumen de lo que se eliminará
                    echo -e "\n${RED}${BOLD}⚠️  ADVERTENCIA: Esta acción es irreversible${NC}"
                    echo -e "${WHITE}Se eliminarán los siguientes pares de snapshots:${NC}"
                    VALID_ROWS=()
                    for row in "${ROWS[@]}"; do
                        if [ "$row" -ge 1 ] && [ "$row" -le "$((INDEX-1))" ]; then
                            SELECTED_LINE=$(sed -n "${row}p" "$TEMP_FILE")
                            R=$(echo "$SELECTED_LINE" | cut -d'|' -f1)
                            H=$(echo "$SELECTED_LINE" | cut -d'|' -f2)
                            D=$(echo "$SELECTED_LINE" | cut -d'|' -f3)
                            echo -e "  ${CYAN}Fila $row${NC} → ROOT: ${GREEN}$R${NC}  HOME: ${GREEN}$H${NC}  ($D)"
                            VALID_ROWS+=("$row")
                        else
                            echo -e "  ${RED}Fila $row: fuera de rango, se omite${NC}"
                        fi
                    done

                    echo -e "\n${WHITE}¿Continuar con la eliminación? (s/N):${NC}"
                    read -r confirm

                    if [[ "$confirm" =~ ^[sS]$ ]]; then
                        # Recopilar números únicos de ROOT y HOME para evitar dobles eliminaciones
                        declare -A SEEN_ROOT SEEN_HOME
                        ROOT_NUMS=()
                        HOME_NUMS=()
                        for row in "${VALID_ROWS[@]}"; do
                            SELECTED_LINE=$(sed -n "${row}p" "$TEMP_FILE")
                            R=$(echo "$SELECTED_LINE" | cut -d'|' -f1)
                            H=$(echo "$SELECTED_LINE" | cut -d'|' -f2)
                            if [ -z "${SEEN_ROOT[$R]}" ]; then
                                ROOT_NUMS+=("$R")
                                SEEN_ROOT[$R]=1
                            fi
                            if [ -z "${SEEN_HOME[$H]}" ]; then
                                HOME_NUMS+=("$H")
                                SEEN_HOME[$H]=1
                            fi
                        done
                        unset SEEN_ROOT SEEN_HOME

                        echo -e "\n${WHITE}${BOLD}RESUMEN DE ELIMINACIÓN:${NC}"

                        if sudo snapper -c root delete "${ROOT_NUMS[@]}" 2>/dev/null; then
                            echo -e "${GREEN}✓ ROOT eliminados: ${ROOT_NUMS[*]}${NC}"
                        else
                            echo -e "${RED}✗ Error al eliminar ROOT: ${ROOT_NUMS[*]}${NC}"
                        fi

                        if sudo snapper -c home delete "${HOME_NUMS[@]}" 2>/dev/null; then
                            echo -e "${GREEN}✓ HOME eliminados: ${HOME_NUMS[*]}${NC}"
                        else
                            echo -e "${RED}✗ Error al eliminar HOME: ${HOME_NUMS[*]}${NC}"
                        fi
                    else
                        echo -e "${YELLOW}Operación cancelada${NC}"
                    fi
                else
                    echo -e "${RED}✗ Entrada inválida${NC}"
                fi
            else
                echo -e "${YELLOW}No se encontraron snapshots con descripciones coincidentes${NC}"
                echo -e "${CYAN}Esto puede suceder si:${NC}"
                echo -e "${CYAN}  • No has creado snapshots con la opción 'AMBOS'${NC}"
                echo -e "${CYAN}  • Las descripciones no coinciden exactamente${NC}"
                echo -e "${CYAN}  • Los snapshots ya fueron eliminados${NC}"
            fi

            rm -f "$TEMP_FILE"

            echo -e "\n${YELLOW}Presiona ENTER para continuar...${NC}"
            read
            show_delete_restore_points
            ;;
        4)
            clear
            show_header "COMANDOS MANUALES DE ELIMINACIÓN"

            show_section "Eliminar un snapshot específico"
            show_command "sudo snapper -c root list                        # Ver snapshots de ROOT"
            show_command "sudo snapper -c home list                        # Ver snapshots de HOME"
            show_command "sudo snapper -c root delete NUMERO               # Eliminar snapshot de ROOT"
            show_command "sudo snapper -c home delete NUMERO               # Eliminar snapshot de HOME"

            show_section "Eliminar un rango de snapshots"
            show_command "sudo snapper -c root delete 5-10                 # Eliminar ROOT del 5 al 10"
            show_command "sudo snapper -c home delete 5-10                 # Eliminar HOME del 5 al 10"

            show_section "Limpieza automática por política"
            show_command "sudo snapper -c root cleanup number              # Limpiar según política numérica"
            show_command "sudo snapper -c home cleanup number"
            show_command "sudo snapper -c root cleanup timeline            # Limpiar según política de tiempo"
            show_command "sudo snapper -c home cleanup timeline"

            show_section "Verificar espacio liberado"
            show_command "df -h /"
            show_command "sudo btrfs filesystem usage /"

            echo -e "\n${YELLOW}Presiona ENTER para volver...${NC}"
            read
            show_delete_restore_points
            ;;
        0)
            return
            ;;
        *)
            echo -e "${RED}Opción inválida${NC}"
            sleep 1
            show_delete_restore_points
            ;;
    esac
}

# Bucle principal del menú
while true; do
    show_menu
    read -r option

    case $option in
        1) show_create_restore_points ;;
        2) show_restore_points ;;
        3) show_delete_restore_points ;;
        4) show_emergency_recovery ;;
        5) show_current_status ;;
        6) show_snapshots ;;
        0) echo -e "${GREEN}¡Gracias por usar la guía BTRFS!${NC}"; exit 0 ;;
        *) echo -e "${RED}Opción inválida. Presiona ENTER para continuar...${NC}"; read ;;
    esac
done
