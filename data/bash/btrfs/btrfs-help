#!/bin/bash
# Guía Interactiva BTRFS y Snapper
# Documentación completa para administración de BTRFS

# Colores para mejor legibilidad
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[1;37m'
NC='\033[0m' # No Color
BOLD='\033[1m'

# Función para mostrar encabezados
show_header() {
    echo -e "\n${PURPLE}${BOLD}╔════════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${PURPLE}${BOLD}║                         $1${NC}"
    echo -e "${PURPLE}${BOLD}╚════════════════════════════════════════════════════════════════╝${NC}\n"
}

# Función para mostrar secciones
show_section() {
    echo -e "\n${CYAN}${BOLD}▶ $1${NC}"
    echo -e "${BLUE}─────────────────────────────────────────────────────${NC}"
}

# Función para mostrar comandos
show_command() {
    echo -e "${GREEN}${BOLD}$ $1${NC}"
}

# Función para mostrar notas importantes
show_note() {
    echo -e "${YELLOW}${BOLD}⚠️  NOTA:${NC} ${YELLOW}$1${NC}"
}

# Función para mostrar tips
show_tip() {
    echo -e "${BLUE}${BOLD}💡 TIP:${NC} ${BLUE}$1${NC}"
}

# Función principal del menú
show_menu() {
    clear
    echo -e "${PURPLE}${BOLD}"
    echo "╔════════════════════════════════════════════════════════════════╗"
    echo "║              HERRAMIENTA PARA GESTIONAR BTRFS                  ║"
    echo "╚════════════════════════════════════════════════════════════════╝"
    echo -e "${NC}"

    echo -e "${WHITE}Selecciona una opción:${NC}\n"
    echo -e "${CYAN}1)${NC}  ➕  Crear Puntos de Restauración"
    echo -e "${CYAN}2)${NC}  ♻️  Restaurar Puntos de Restauración"
    echo -e "${CYAN}3)${NC}  🗑️  Eliminar Puntos de Restauración"
    echo -e "${CYAN}4)${NC}  ⚠️  Recuperación de Emergencia (GRUB)"
    echo -e "${CYAN}5)${NC}  💻  Ver Estado Actual de Snaps"
    echo -e "${CYAN}6)${NC}  🗂️  Gestión de Snapshots con Snapper"
    echo -e "${CYAN}0)${NC}  ✗  Salir"

    echo -e "\n${YELLOW}Ingresa tu opción: ${NC}"
}

# Función para gestión de snapshots
show_snapshots() {
    clear
    show_header "GESTIÓN DE SNAPSHOTS CON SNAPPER"

    echo -e "${WHITE}Selecciona una opción:${NC}\n"
    echo -e "${CYAN}1)${NC} 📋  Ver configuración actual de snapshots automáticos"
    echo -e "${CYAN}2)${NC} ⏰  Cambiar frecuencia de snapshots automáticos"
    echo -e "${CYAN}3)${NC} 📖  Ver comandos básicos de snapper"
    echo -e "${CYAN}0)${NC} ✗  Volver al menú principal"

    echo -e "\n${YELLOW}Ingresa tu opción: ${NC}"
    read -r option

    case $option in
        1)
            clear
            show_header "CONFIGURACIÓN ACTUAL DE SNAPSHOTS AUTOMÁTICOS"

            show_section "📋 Política de Retención Configurada"
            echo -e "${WHITE}${BOLD}✓ ROOT (/):${NC} Sistema operativo protegido automáticamente"
            echo -e "${CYAN}  • Cada hora: mantiene 5 snapshots${NC}"
            echo -e "${CYAN}  • Diarios: mantiene 7 snapshots${NC}"
            echo -e "${CYAN}  • Semanales: mantiene 4 snapshots${NC}"
            echo -e "${CYAN}  • Mensuales: mantiene 6 snapshots${NC}"
            echo -e "${CYAN}  • Anuales: mantiene 2 snapshots${NC}"

            echo -e "\n${WHITE}${BOLD}✓ HOME (/home):${NC} Datos de usuario protegidos automáticamente"
            echo -e "${CYAN}  • Cada hora: mantiene 3 snapshots${NC}"
            echo -e "${CYAN}  • Diarios: mantiene 7 snapshots${NC}"
            echo -e "${CYAN}  • Semanales: mantiene 4 snapshots${NC}"
            echo -e "${CYAN}  • Mensuales: mantiene 12 snapshots (más para datos importantes)${NC}"
            echo -e "${CYAN}  • Anuales: mantiene 5 snapshots${NC}"

            echo -e "\n${WHITE}${BOLD}📍 Ubicación:${NC} /.snapshots y /home/.snapshots"

            show_section "⏰ Frecuencia Actual de Creación"
            echo -e "${WHITE}Programación del temporizador snapper-timeline.timer:${NC}"
            sudo systemctl list-timers snapper-timeline.timer --no-pager 2>/dev/null || echo -e "${YELLOW}No se pudo consultar el temporizador${NC}"
            echo -e "\n${CYAN}  • snapper-cleanup.timer limpia diariamente${NC}"
            echo -e "${YELLOW}  • Para cambiar cada cuánto se crean snapshots, usa la opción 2 del menú anterior${NC}"

            show_section "⚠️ BOOT DESDE SNAPSHOTS (GRUB-BTRFS)"
            echo -e "${WHITE}${BOLD}✓ Configurado para arrancar desde snapshots:${NC}"
            echo -e "${CYAN}  • En GRUB verás 'Arch Linux snapshots' como opción${NC}"
            echo -e "${CYAN}  • Permite arrancar desde cualquier snapshot cuando el sistema falla${NC}"
            echo -e "${CYAN}  • Última opción de recuperación si no puedes acceder al sistema${NC}"

            show_note "grub-btrfs se actualiza automáticamente cuando se crean nuevos snapshots"

            show_section "⚠️ Información Importante ⚠️"
            echo -e "• ${GREEN}Los snapshots automáticos funcionan sin intervención${NC}"
            echo -e "• ${GREEN}La limpieza automática evita que se llene el disco${NC}"
            echo -e "• ${GREEN}Los snapshots ocupan espacio solo para los cambios (CoW)${NC}"
            echo -e "• ${YELLOW}Para snapshots con descripción personal, usa opciones 1 y 2 del menú principal${NC}"

            echo -e "\n${YELLOW}Presiona ENTER para volver...${NC}"
            read
            show_snapshots
            ;;
        2)
            show_snapshot_frequency
            show_snapshots
            ;;
        3)
            clear
            show_header "COMANDOS BÁSICOS DE SNAPPER"

            show_section "📋 Ver Snapshots"
            show_command "sudo snapper -c root list                    # Ver snapshots de ROOT"
            show_command "sudo snapper -c home list                    # Ver snapshots de HOME"
            show_command "sudo snapper list-configs                    # Ver configuraciones"

            echo -e "\n${WHITE}Comparar snapshots:${NC}"
            show_command "sudo snapper -c root status 1..5             # Comparar snapshots de ROOT"
            show_command "sudo snapper -c home diff 3..7               # Ver diferencias de HOME"

            show_section "⚠️ Limpieza de Snapshots"
            show_command "sudo snapper -c root cleanup timeline        # Limpieza automática ROOT"
            show_command "sudo snapper -c home cleanup timeline        # Limpieza automática HOME"
            show_command "sudo snapper -c root delete 5 6 7            # Eliminar snapshots específicos"

            show_section "⚙️ Estado de Servicios"
            show_command "sudo systemctl status snapper-timeline.timer # Estado snapshots automáticos"
            show_command "sudo systemctl status snapper-cleanup.timer  # Estado limpieza automática"
            show_command "sudo systemctl list-timers snapper-*         # Ver próximas ejecuciones"

            echo -e "\n${YELLOW}Presiona ENTER para volver...${NC}"
            read
            show_snapshots
            ;;
        0)
            return
            ;;
        *)
            echo -e "${RED}Opción inválida${NC}"
            sleep 1
            show_snapshots
            ;;
    esac
}

# Función para cambiar la frecuencia de creación de snapshots automáticos
show_snapshot_frequency() {
    clear
    show_header "FRECUENCIA DE SNAPSHOTS AUTOMÁTICOS"

    show_note "Esto cambia cada cuánto se CREAN snapshots (snapper-timeline.timer). Aplica a todas las configuraciones (ROOT y HOME)."

    echo -e "\n${WHITE}Frecuencia actual:${NC}"
    sudo systemctl list-timers snapper-timeline.timer --no-pager 2>/dev/null || echo -e "${YELLOW}No se pudo consultar el temporizador${NC}"

    echo -e "\n${WHITE}Selecciona la nueva frecuencia:${NC}\n"
    echo -e "${CYAN}1)${NC} Cada hora (valor por defecto)"
    echo -e "${CYAN}2)${NC} Una vez al día"
    echo -e "${CYAN}3)${NC} Una vez a la semana"
    echo -e "${CYAN}4)${NC} Una vez al mes"
    echo -e "${CYAN}5)${NC} Varias veces por semana (elige cuántas)"
    echo -e "${CYAN}6)${NC} Varias veces al mes (elige cuántas)"
    echo -e "${CYAN}0)${NC} ✗  Cancelar / Volver"

    echo -e "\n${YELLOW}Ingresa tu opción: ${NC}"
    read -r freq_option

    ON_CALENDAR=""
    DESCRIPCION=""

    case $freq_option in
        1)
            ON_CALENDAR="hourly"
            DESCRIPCION="cada hora"
            ;;
        2)
            ON_CALENDAR="daily"
            DESCRIPCION="una vez al día (03:00)"
            ;;
        3)
            ON_CALENDAR="weekly"
            DESCRIPCION="una vez a la semana (lunes 03:00)"
            ;;
        4)
            ON_CALENDAR="monthly"
            DESCRIPCION="una vez al mes (día 1, 03:00)"
            ;;
        5)
            echo -e "\n${WHITE}¿Cuántas veces por semana? (1-7):${NC}"
            read -r n_semana
            case $n_semana in
                1) DIAS="Mon" ;;
                2) DIAS="Mon,Thu" ;;
                3) DIAS="Mon,Wed,Fri" ;;
                4) DIAS="Mon,Tue,Thu,Fri" ;;
                5) DIAS="Mon,Tue,Wed,Thu,Fri" ;;
                6) DIAS="Mon,Tue,Wed,Thu,Fri,Sat" ;;
                7) DIAS="*" ;;
                *)
                    echo -e "${RED}✗ Valor inválido${NC}"
                    sleep 1
                    show_snapshot_frequency
                    return
                    ;;
            esac
            ON_CALENDAR="$DIAS *-*-* 03:00:00"
            DESCRIPCION="$n_semana vez(es) por semana ($DIAS, 03:00)"
            ;;
        6)
            echo -e "\n${WHITE}¿Cuántas veces al mes? (1-4):${NC}"
            read -r n_mes
            case $n_mes in
                1) DIAS_MES="01" ;;
                2) DIAS_MES="01,15" ;;
                3) DIAS_MES="01,10,20" ;;
                4) DIAS_MES="01,08,15,22" ;;
                *)
                    echo -e "${RED}✗ Valor inválido${NC}"
                    sleep 1
                    show_snapshot_frequency
                    return
                    ;;
            esac
            ON_CALENDAR="*-*-$DIAS_MES 03:00:00"
            DESCRIPCION="$n_mes vez(es) al mes (días $DIAS_MES, 03:00)"
            ;;
        0)
            return
            ;;
        *)
            echo -e "${RED}Opción inválida${NC}"
            sleep 1
            show_snapshot_frequency
            return
            ;;
    esac

    echo -e "\n${WHITE}Se configurará la creación de snapshots: ${GREEN}$DESCRIPCION${NC}"
    echo -e "${WHITE}¿Continuar? (s/N):${NC}"
    read -r confirm

    if [[ "$confirm" =~ ^[sS]$ ]]; then
        echo -e "\n${CYAN}Aplicando nueva frecuencia...${NC}"
        sudo mkdir -p /etc/systemd/system/snapper-timeline.timer.d
        {
            echo "[Timer]"
            echo "OnCalendar="
            echo "OnCalendar=$ON_CALENDAR"
        } | sudo tee /etc/systemd/system/snapper-timeline.timer.d/override.conf >/dev/null

        if sudo systemctl daemon-reload && sudo systemctl restart snapper-timeline.timer; then
            echo -e "${GREEN}✓ Frecuencia actualizada: $DESCRIPCION${NC}"
            echo -e "\n${WHITE}Próxima ejecución:${NC}"
            sudo systemctl list-timers snapper-timeline.timer --no-pager 2>/dev/null
        else
            echo -e "${RED}✗ Error al aplicar la nueva frecuencia${NC}"
        fi
    else
        echo -e "${YELLOW}Operación cancelada${NC}"
    fi

    echo -e "\n${YELLOW}Presiona ENTER para volver...${NC}"
    read
}

