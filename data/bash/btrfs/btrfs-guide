    echo -e "\n${WHITE}${BOLD}Para restaurar HOME:${NC}"
    show_command "sudo snapper -c home list                     # Ver snapshots de HOME"
    show_command "sudo snapper -c home undochange 1..0          # Restaurar snapshot 1 (cambiar número)"
